# ─────────────────────────────────────────────
#  24hr Gym Monitor — Environment Variables
# ─────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.

# ── Telegram ──────────────────────────────────
# Get from @BotFather on Telegram (/newbot)
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Your personal Telegram chat ID
# 1. Message your bot anything
# 2. Visit: https://api.telegram.org/bot<BOT_TOKEN>/getUpdates
# 3. Find "chat":{"id": XXXXXXXX} in the response
CHAT_ID=123456789

# ── BestTime.app ──────────────────────────────
# Get a free API key at https://besttime.app
BESTTIME_API_KEY=pri_...

# ── Busyness Thresholds ───────────────────────
# Below this % → 🟢 Quiet (alert sent: "Go now!")
QUIET_THRESHOLD=35
# Above this % → 🔴 Busy (alert sent: "Skip it, too busy")
BUSY_THRESHOLD=65

# ── Schedule ──────────────────────────────────
# How often to check (in minutes)
CHECK_INTERVAL_MINUTES=15
# Time to send daily "best windows" digest (24hr format, local time)
DAILY_DIGEST_TIME=08:00
